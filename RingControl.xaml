<UserControl x:Class="IndustrialInspectionWPF.RingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="32" Height="32" Cursor="Hand">
    <Grid>
        <!-- 外环 -->
        <Ellipse x:Name="Outer" Fill="White" Stroke="Black" StrokeThickness="1"/>
        <!-- 内圆 -->
        <Ellipse x:Name="Inner" Fill="White" Stroke="Black" StrokeThickness="1"
                 Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <!-- 编号 (仅开发可见，不需要可隐藏) -->
        <TextBlock x:Name="TxtID" HorizontalAlignment="Center" VerticalAlignment="Center" 
                   FontSize="9" Foreground="Gray" IsHitTestVisible="False"/>
        <!-- 点击区域 -->
        <Rectangle Fill="Transparent" MouseLeftButtonDown="OnMouseClick"/>
    </Grid>
</UserControl>