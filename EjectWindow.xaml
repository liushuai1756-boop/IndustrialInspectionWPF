<Window x:Class="IndustrialInspectionWPF.EjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="剔除确认" Height="220" Width="380" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None"
        Background="White" BorderBrush="#FF8C00" BorderThickness="2">

    <Window.Effect>
        <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
    </Window.Effect>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Background="#FF8C00" Grid.Row="0">
            <TextBlock Text="⚠ 剔除警告" Foreground="White" FontSize="18" FontWeight="Bold" 
                       VerticalAlignment="Center" Margin="20,0"/>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock x:Name="TxtMsg" Text="确认剔除位置 #XX ?" FontSize="20" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center"/>
            <TextBlock Text="此操作不可撤销" FontSize="14" Foreground="Red" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="确认剔除" Click="BtnConfirm_Click" Background="#FF8C00" Foreground="White" FontSize="16" FontWeight="Bold"/>
            <Button Grid.Column="2" Content="取消" Click="BtnCancel_Click" Background="Gray" Foreground="White" FontSize="16"/>
        </Grid>
    </Grid>
</Window>