<Window x:Class="IndustrialInspectionWPF.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统运行日志" Height="600" Width="500" ShowInTaskbar="False">
    <Grid>
        <TextBox x:Name="TxtLogContent" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                 FontFamily="Consolas" FontSize="14" Padding="10" TextWrapping="Wrap"/>
    </Grid>
</Window>