<Window x:Class="IndustrialInspectionWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P1X0 铝线检测系统" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#E0E0E0">

    <Window.Resources>
        <!-- 3D立体质感按钮样式 -->
        <Style TargetType="Button" x:Key="3DButtonStyle">
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Border" CornerRadius="6" BorderBrush="#888" BorderThickness="1">
                                <Border.Background>
                                    <!-- 线性渐变模拟凸起感 -->
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFFF" Offset="0.0"/>
                                        <GradientStop Color="#DDDDDD" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.2" BlurRadius="2"/>
                                </Border.Effect>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,5">
                                    <TextBlock Text="{TemplateBinding Content}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <!-- 指示灯 -->
                                    <Border Width="18" Height="18" CornerRadius="9" 
                                            Background="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, TargetNullValue=Gold}" 
                                            BorderBrush="#666" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="3" Color="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, TargetNullValue=Gold}"/>
                                        </Border.Effect>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- 鼠标悬停变亮 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                            <!-- 鼠标按下：反转渐变 + 偏移 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Border" Property="Background" Value="#CCCCCC"/>
                                <Setter TargetName="Border" Property="Effect" Value="{x:Null}"/>
                                <!-- 去掉阴影 -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 普通功能按钮样式 (无灯) -->
        <Style TargetType="Button" x:Key="FuncBtnStyle" BasedOn="{StaticResource 3DButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Border" CornerRadius="6" BorderBrush="#888" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#F0F0F0" Offset="0"/>
                                        <GradientStop Color="#D0D0D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.2" BlurRadius="2"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Border" Property="Background" Value="#BBBBBB"/>
                                <Setter TargetName="Border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Grid -->
            <RowDefinition Height="90"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- 1. 头部：标题 + 统计 + 设置 -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="P1X0 PE铝线检测系统" FontSize="28" FontWeight="Bold" Foreground="#222"/>

                <!-- 统计面板 (仅自动模式有效) -->
                <Border Margin="30,0,0,0" Background="White" CornerRadius="5" Padding="15,5" BorderBrush="#CCC" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="OK: " FontWeight="Bold" FontSize="20" Foreground="#222"/>
                        <TextBlock x:Name="TxtOK" Text="0" FontWeight="Bold" FontSize="20" Foreground="LimeGreen" Margin="0,0,20,0"/>

                        <TextBlock Text="NG: " FontWeight="Bold" FontSize="20" Foreground="#222"/>
                        <TextBlock x:Name="TxtNG" Text="0" FontWeight="Bold" FontSize="20" Foreground="Red"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 右侧 -->
            <!-- 右侧：通讯状态 + 设置 + Logo -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">

                <!-- [新增] 通讯状态指示器 -->
                <Border Background="White" CornerRadius="6" BorderBrush="#AAA" BorderThickness="1" Margin="0,0,15,0" Padding="10,5">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="5" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <!-- LED 灯 -->
                        <Border x:Name="LedComm" Width="16" Height="16" CornerRadius="8" Background="Gray" BorderBrush="#666" BorderThickness="1" Margin="0,0,8,0">
                            <Border.Effect>
                                <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="0" x:Name="LedShadow"/>
                            </Border.Effect>
                        </Border>
                        <TextBlock x:Name="TxtComm" Text="PLC 未连接" VerticalAlignment="Center" FontWeight="Bold" Foreground="Gray" FontSize="14"/>
                    </StackPanel>
                </Border>

                <!-- 设置按钮 -->
                <Button Content="⚙️ 参数设置" Click="BtnSettings_Click" Style="{StaticResource FuncBtnStyle}" Width="110" Height="40" Margin="0,0,20,0"/>

                <!-- Logo -->
                <Image Source="pack://siteoforigin:,,,/logo.png" Height="50" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
            </StackPanel>
        </Grid>

        <!-- 2. 网格区域 (Viewbox 自动充满) -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#AAA" BorderThickness="1" Margin="0,15">
            <!-- 加上 DropShadow 让网格卡片更有层次 -->
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="0"/>
            </Border.Effect>

            <Viewbox Margin="20">
                <!-- 逻辑画布：1400x500，圆环尺寸加大 -->
                <Canvas x:Name="GridCanvas" Width="1400" Height="500"/>
            </Viewbox>
        </Border>

        <!-- 3. 底部控制栏 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <!-- 日志按钮区 -->
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="BtnReset" Content="复位初始" Click="BtnMode_Click" Style="{StaticResource 3DButtonStyle}" Tag="Gold" Height="50"/>
            <Button Grid.Column="1" x:Name="BtnAuto" Content="自动模式" Click="BtnMode_Click" Style="{StaticResource 3DButtonStyle}" Tag="Gold" Height="50"/>
            <Button Grid.Column="2" x:Name="BtnRecheck" Content="复检模式" Click="BtnMode_Click" Style="{StaticResource 3DButtonStyle}" Tag="Gold" Height="50"/>
            <Button Grid.Column="3" x:Name="BtnEject" Content="剔除模式" Click="BtnMode_Click" Style="{StaticResource 3DButtonStyle}" Tag="Gold" Height="50"/>

            <Button Grid.Column="4" Content="📜日志" Click="BtnShowLog_Click" Style="{StaticResource FuncBtnStyle}" Height="50"/>
        </Grid>
    </Grid>
</Window>