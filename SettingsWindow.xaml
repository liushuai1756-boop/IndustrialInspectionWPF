<Window x:Class="IndustrialInspectionWPF.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统参数配置" Height="700" Width="900" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F0F0">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 1. S7 连接配置 -->
        <GroupBox Header="S7 PLC 连接配置" Grid.Row="0" Margin="0,0,0,10" Padding="10" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="IP地址:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtIP" Grid.Column="1" Margin="5"/>
                <TextBlock Text="Rack:" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <TextBox x:Name="TxtRack" Grid.Column="3" Margin="5"/>
                <TextBlock Text="Slot:" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <TextBox x:Name="TxtSlot" Grid.Column="5" Margin="5"/>
                <TextBlock Text="DB块:" Grid.Column="6" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold"/>
                <TextBox x:Name="TxtDbNum" Grid.Column="7" Margin="5" FontWeight="Bold" Background="#EEE" IsReadOnly="True" Focusable="False" Foreground="Gray"/>
            </Grid>
        </GroupBox>

        <!-- 2. 指令码配置 -->
        <GroupBox Header="交互指令码配置 (Int)" Grid.Row="1" Margin="0,0,0,10" Padding="10" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <TextBlock Text="复位模式 (发/收):" VerticalAlignment="Center" Grid.Row="0"/>
                <TextBox x:Name="TxtResetReq" Grid.Row="0" Grid.Column="1" Margin="2"/>
                <TextBox x:Name="TxtResetAck" Grid.Row="0" Grid.Column="4" Margin="2"/>

                <TextBlock Text="自动模式 (发/收):" VerticalAlignment="Center" Grid.Row="1"/>
                <TextBox x:Name="TxtAutoReq" Grid.Row="1" Grid.Column="1" Margin="2"/>
                <TextBox x:Name="TxtAutoAck" Grid.Row="1" Grid.Column="4" Margin="2"/>

                <TextBlock Text="复检模式 (发/收):" VerticalAlignment="Center" Grid.Row="2"/>
                <TextBox x:Name="TxtRecheckReq" Grid.Row="2" Grid.Column="1" Margin="2"/>
                <TextBox x:Name="TxtRecheckAck" Grid.Row="2" Grid.Column="4" Margin="2"/>

                <TextBlock Text="剔除模式 (发/收):" VerticalAlignment="Center" Grid.Row="3"/>
                <TextBox x:Name="TxtEjectReq" Grid.Row="3" Grid.Column="1" Margin="2"/>
                <TextBox x:Name="TxtEjectAck" Grid.Row="3" Grid.Column="4" Margin="2"/>

                <TextBlock Text="信号 (到位/数据应答):" VerticalAlignment="Center" Grid.Row="4"/>
                <TextBox x:Name="TxtReady" Grid.Row="4" Grid.Column="1" Margin="2" Background="#E6F7FF"/>
                <TextBox x:Name="TxtDataAck" Grid.Row="4" Grid.Column="4" Margin="2" Background="#E6F7FF"/>
            </Grid>
        </GroupBox>

        <!-- 3. 地址说明表 (带实时监控) -->
        <GroupBox Header="PLC 地址监控 (实时)" Grid.Row="2" Background="White">
            <DataGrid x:Name="GridAddr" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal" Background="White" RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="变量名" Binding="{Binding Name}" Width="120"/>
                    <DataGridTextColumn Header="PLC 地址" Binding="{Binding Address}" Width="100" FontWeight="Bold" Foreground="Blue"/>
                    <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="60"/>
                    <DataGridTextColumn Header="方向" Binding="{Binding Direction}" Width="60"/>
                    <DataGridTextColumn Header="功能描述" Binding="{Binding Desc}" Width="*"/>

                    <!-- 新增两列 -->
                    <DataGridTextColumn Header="当前值" Binding="{Binding CurrentValue}" Width="80" FontWeight="Bold" Foreground="#D50000"/>

                    <DataGridTemplateColumn Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="读取" Click="BtnRead_Click" Height="22" Width="50" Cursor="Hand" Background="#E0E0E0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- 4. 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="💾 保存配置" Click="BtnSave_Click" Width="100" Height="35" Background="#32CD32" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="取消" Click="BtnCancel_Click" Width="80" Height="35"/>
        </StackPanel>
    </Grid>
</Window>