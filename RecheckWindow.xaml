<Window x:Class="IndustrialInspectionWPF.RecheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="人工判定" Height="250" Width="400" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None"
        Background="White" BorderBrush="#007ACC" BorderThickness="2">

    <!-- 窗口阴影效果 -->
    <Window.Effect>
        <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
    </Window.Effect>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Background="#007ACC" Grid.Row="0">
            <TextBlock Text="复检结果确认" Foreground="White" FontSize="18" FontWeight="Bold" 
                       VerticalAlignment="Center" Margin="20,0"/>
        </Border>

        <!-- 内容提示 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="TxtMsg" Text="请确认位置 #XX 的复检结果" FontSize="18" Foreground="#333" TextAlignment="Center"/>
            <TextBlock Text="请仔细观察实物" FontSize="14" Foreground="#888" Margin="0,10,0,0" TextAlignment="Center"/>
        </StackPanel>

        <!-- 按钮区 -->
        <Grid Grid.Row="2" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- OK 按钮 (绿色) -->
            <Button Grid.Column="0" Content="确认 OK" Click="BtnOK_Click" Cursor="Hand" FontSize="16" FontWeight="Bold" Foreground="White">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#32CD32" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#228B22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- NG 按钮 (红色) -->
            <Button Grid.Column="2" Content="确认 NG" Click="BtnNG_Click" Cursor="Hand" FontSize="16" FontWeight="Bold" Foreground="White">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#FF4444" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#CC0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>